# Copy this to .env.local and fill in your values
# Same-origin Frappe hosting is preferred. Leave VITE_FRAPPE_BASE_URL blank to use the current site origin.
VITE_FRAPPE_BASE_URL=https://btm.digihoopoe.com

# Optional: only needed for cross-site testing or local development.
# The dashboard uses the logged-in Frappe session cookie when it is served from the same site.
VITE_API_KEY=your_api_key_here
VITE_API_SECRET=your_api_secret_here
