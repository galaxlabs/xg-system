# ── Local Development ──────────────────────────────────────────
# Copy this to .env.local
VITE_FRAPPE_BASE_URL=https://btm.digihoopoe.com

# ── Vercel Deployment (set in Vercel Dashboard, NOT in .env) ──
# 1. Do NOT set VITE_FRAPPE_BASE_URL — the proxy handles routing
# 2. Set these server-side env vars for API auth:
#    FRAPPE_BASE_URL=https://btm.digihoopoe.com
#    API_KEY=your_api_key
#    API_SECRET=your_api_secret
# 3. The frontend calls relative URLs → proxy → Frappe backend
